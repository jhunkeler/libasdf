# Tests
# 'check' comes from 'make check'
AM_CPPFLAGS = \
    -I$(top_srcdir)/include \
    -I$(top_srcdir)/third_party/STC/include \
    -I$(top_srcdir)/src

asdf_standard_dir = $(abs_top_srcdir)/asdf-standard
asdf_standard_submodule = $(asdf_standard_dir)/.git
munit_dir = $(top_builddir)/tests/munit
munit_submodule = $(munit_dir)/.git
munit_cflags = -std=c11 -I$(top_srcdir)/tests
munit_ldflags = $(builddir)/libmunit.a
submodules = $(asdf_standard_submodule) $(munit_submodule)

$(asdf_standard_submodule) $(munit_submodule):
	@if test -d $(top_srcdir)/.git; then \
	    echo "Initializing submodules $@ ..."; \
	    git submodule update --init --recursive; \
	    git config submodule.tests/munit.ignore untracked; \
	else \
	    echo "Skipping submodule init: not in a Git repository"; \
	fi


@VALGRIND_CHECK_RULES@

check_PROGRAMS = \
    test-block.unit \
    test-compression.unit \
    test-core-extensions.unit \
    test-event.unit \
    test-extension.unit \
    test-file.unit \
    test-ndarray.unit \
    test-parse-util.unit \
    test-parser.unit \
    test-stream.unit \
    test-tests.unit \
    test-value.unit \
    test-value-util.unit \
    test-yaml.unit

TESTS_ENVIRONMENT = top_builddir=$(top_builddir) top_srcdir=$(top_srcdir)
TESTS = $(check_PROGRAMS)

unit_test_base_cppflags = \
    -DREFERENCE_FILES_DIR=\"$(asdf_standard_dir)/reference_files\" \
    -DFIXTURES_DIR=\"$(abs_srcdir)/fixtures\" \
    -DTEMP_DIR=\"$(abs_builddir)/tmp\" \
    -D_GNU_SOURCE

