# Shell tests
TOOL_TESTS = test-events.sh test-info.sh

if HAVE_MD5
    TOOL_TESTS += test-verify-checksums.sh
endif

if ASDF_BUILD_TOOL
TESTS += $(TOOL_TESTS)
else
$(warning Skipping running asdf command-line tests; make sure to run ./configure --enable-tool; make to build the tool)
endif

QUIET_OUT = $(if $(filter 1,$(V)),, > /dev/null)


# Test headers on C++
cpp_header_test = $(builddir)/test-cpp-headers.cpp
# Generate the C++ header test file
$(cpp_header_test): $(asdf_public_headers) $(srcdir)/scripts/generate_test_cpp_headers.sh
	$(AM_V_at)$(srcdir)/scripts/generate_test_cpp_headers.sh \
	    $(top_srcdir)/include $@ $(asdf_public_headers) \
	    $(QUIET_OUT)

test-cpp-headers$(EXEEXT): $(cpp_header_test) $(top_builddir)/libasdf.la
	$(AM_V_at)$(LIBTOOL) --mode=link $(CXX) -std=c++17 -I$(top_srcdir)/include \
	    $(ASDF_LDFLAGS) $(unit_test_ldflags) $(cpp_header_test) $(top_builddir)/libasdf.la $(ASDF_LIBS) \
	    -o $@ $(QUIET_OUT)

TESTS += test-cpp-headers
CLEANFILES = test-cpp-headers.cpp test-cpp-headers$(EXEEXT)


# Check examples in the documentation
if HAVE_PYTHON
DOC_EXAMPLES_DIR = $(builddir)/doc_examples
# Documentation files containing example programs
DOC_EXAMPLE_FILES = \
    $(top_srcdir)/README.rst \
    $(top_srcdir)/docs/usage/writing.rst

DOC_EXAMPLE_DEPS = \
    $(DOC_EXAMPLE_FILES) \
    $(srcdir)/scripts/extract_doc_examples.py \
    $(top_builddir)/libasdf.la

TESTS += $(DOC_EXAMPLES_DIR)/test-doc-examples.sh


$(DOC_EXAMPLES_DIR)/test-doc-examples.sh: $(DOC_EXAMPLE_DEPS)
	$(AM_V_at)$(PYTHON3) $(srcdir)/scripts/extract_doc_examples.py \
	  $(top_srcdir)/README.rst \
	  $(top_srcdir)/docs/usage/writing.rst \
	  --out-dir $(DOC_EXAMPLES_DIR) \
	  --fixtures-dir $(srcdir)/fixtures $(QUIET_OUT)
	$(AM_V_at)for f in $(DOC_EXAMPLES_DIR)/*.c; do \
	    exe=$${f%.c}; \
	    $(LIBTOOL) --mode=link $(CC) $(ASDF_CFLAGS) -I$(top_srcdir)/include \
	      $(ASDF_LDFLAGS) $(unit_test_ldflags) $$f $(top_builddir)/libasdf.la $(ASDF_LIBS) \
	      -o $$exe $(QUIET_OUT); \
	done

endif

AUTOMAKE_OPTIONS = parallel-tests

